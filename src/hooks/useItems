// @ts-nocheck

const STORAGE_KEY = 'streamlist_items';

export function readItems() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    return raw ? JSON.parse(raw) : [];
  } catch {
    return [];
  }
}

export function writeItems(items) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
}

const genId = () => {
  if (typeof crypto !== 'undefined' && crypto.randomUUID) return crypto.randomUUID();
  return `${Date.now()}-${Math.random().toString(16).slice(2)}`;
};

export function addItem(items, title) {
  const now = Date.now();
  const newItem = { id: genId(), title, completed: false, createdAt: now, updatedAt: now };
  const next = [...items, newItem];
  writeItems(next);
  return next;
}

export function deleteItem(items, id) {
  const next = items.filter((i) => i.id !== id);
  writeItems(next);
  return next;
}

export function toggleItem(items, id) {
  const next = items.map((i) =>
    i.id === id ? { ...i, completed: !i.completed, updatedAt: Date.now() } : i
  );
  writeItems(next);
  return next;
}

export function updateItem(items, id, title) {
  const t = title.trim();
  const next = items.map((i) =>
    i.id === id ? { ...i, title: t || i.title, updatedAt: Date.now() } : i
  );
  writeItems(next);
  return next;
}

// Distinct recent titles by reverse recency (last 5)
export function recentTitles(items, limit = 5) {
  const out = [];
  const seen = new Set();
  for (let idx = items.length - 1; idx >= 0 && out.length < limit; idx--) {
    const t = items[idx].title;
    if (!seen.has(t)) {
      seen.add(t);
      out.push(t);
    }
  }
  return out;
}